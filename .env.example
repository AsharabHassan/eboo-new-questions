# Copy this file to .env.local and fill in real values.
# All vars are optional — the app gracefully degrades if a service isn't configured.

# ---------- GoHighLevel calendar ----------
# Booking widget URL for your free consultation calendar.
# Get it from HighLevel: Calendars > [your calendar] > Share > Permanent Link.
# Format: https://api.leadconnectorhq.com/widget/booking/{calendar_id}
NEXT_PUBLIC_GHL_CALENDAR_URL=

# Separate URL for screening calls (used when a quiz flags a safety contraindication).
# Falls back to NEXT_PUBLIC_GHL_CALENDAR_URL if not set.
NEXT_PUBLIC_GHL_SCREENING_CALENDAR_URL=

# ---------- GoHighLevel inbound webhook (CRM ingestion) ----------
# Server-side webhook URL where every completed quiz is POSTed as flat JSON.
# Setup: GHL > Automation > Workflows > New Workflow > Inbound Webhook trigger.
# Copy the webhook URL here, then in the workflow map JSON fields like
# first_name / email / toxic_load_score / protocol_track / safety_status /
# answer_lifestyle / answer_symptoms / ... to your contact custom fields.
# Format: https://services.leadconnectorhq.com/hooks/{location_id}/webhook-trigger/{trigger_id}
GHL_WEBHOOK_URL=

# ---------- Resend (transactional email) ----------
# Get a key at https://resend.com — free tier sends 3,000 emails/month.
RESEND_API_KEY=

# Verified domain the emails send FROM. Must be a domain you control.
# Example: HSW Assessment <noreply@hsw.london>
RESEND_FROM="HSW Assessment <noreply@example.com>"

# Where new lead notifications go (the clinic inbox).
CLINIC_EMAIL=hello@example.com

# ---------- Optional: app base URL (used in email links, sitemap, OG) ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Plausible Analytics (privacy-friendly, cookieless) ----------
# Your verified domain in Plausible. Leave blank to disable analytics in dev.
# Example: hsw.london
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---------- Meta Pixel + Conversions API ----------
# Browser-side Pixel ID. Public — exposed in client bundle. Fires PageView
# automatically and `Lead` when a quiz completes. Defaults to the hardcoded
# project pixel if unset; override here for staging/production splits.
NEXT_PUBLIC_META_PIXEL_ID=823507040655170

# Server-side Pixel ID for the Conversions API (usually the same value).
META_PIXEL_ID=823507040655170

# CAPI access token. Generate in Events Manager:
#   Data Sources > [your pixel] > Settings > Conversions API > Generate Access Token
META_CAPI_ACCESS_TOKEN=

# Optional: test event code from Events Manager > Test Events.
# Set this only while validating; remove for production traffic.
META_CAPI_TEST_CODE=
